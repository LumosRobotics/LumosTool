#!/usr/bin/env bash
# Submits a new Lumos version to the Windows Package Manager (winget) by
# opening a pull request against microsoft/winget-pkgs.
#
# Prerequisites (one-time setup):
#   1. Fork microsoft/winget-pkgs on GitHub
#   2. gh auth login (already done if you use publish_release)
#
# Usage: ./scripts/publish_winget [version]
#   version defaults to the version in packages/winget/LumosRobotics.Lumos.yaml

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WINGET_PKGS_REPO="microsoft/winget-pkgs"
WINGET_PKGS_LOCAL="$(cd "$REPO_ROOT/../winget-pkgs" && pwd)"
GITHUB_REPO="LumosRobotics/LumosTool"
MANIFESTS_DIR="$REPO_ROOT/packages/winget"

# ── Resolve version ────────────────────────────────────────────────────────────
VERSION="${1:-}"
if [ -z "$VERSION" ]; then
    VERSION=$(python3 -c "
import re, pathlib
src = pathlib.Path('$MANIFESTS_DIR/LumosRobotics.Lumos.yaml').read_text()
print(re.search(r'^PackageVersion:\s*(.+)', src, re.M).group(1).strip())
")
fi
echo "==> Version: $VERSION"

WINDOWS_ZIP="$REPO_ROOT/release/lumos-windows-${VERSION}.zip"
SHA256_FILE="${WINDOWS_ZIP}.sha256"

if [ ! -f "$SHA256_FILE" ]; then
    echo "Error: $SHA256_FILE not found. Run create_windows_release.py first."
    exit 1
fi

SHA256=$(awk '{print $1}' "$SHA256_FILE" | tr '[:lower:]' '[:upper:]')
echo "==> SHA256: $SHA256"

# ── Generate versioned manifests ───────────────────────────────────────────────
echo ""
echo "==> Generating manifests for v${VERSION}..."

MANIFEST_PATH="manifests/l/LumosRobotics/Lumos/${VERSION}"
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

mkdir -p "$TMP_DIR/$MANIFEST_PATH"

python3 - <<PYEOF
import re, pathlib, shutil

version  = "$VERSION"
sha256   = "$SHA256"
src_dir  = pathlib.Path("$MANIFESTS_DIR")
dst_dir  = pathlib.Path("$TMP_DIR/$MANIFEST_PATH")
zip_url  = f"https://github.com/$GITHUB_REPO/releases/download/v{version}/lumos-windows-{version}.zip"
nested   = f"lumos-windows-{version}\\\\bin\\\\lumos.exe"

for src in src_dir.glob("*.yaml"):
    content = src.read_text()
    content = re.sub(r'PackageVersion:\s*.+',       f'PackageVersion: {version}',  content)
    content = re.sub(r'InstallerUrl:\s*.+',          f'InstallerUrl: {zip_url}',    content)
    content = re.sub(r'InstallerSha256:\s*.+',       f'InstallerSha256: {sha256}',  content)
    content = re.sub(r'RelativeFilePath:\s*.+',      f'RelativeFilePath: {nested}', content)
    (dst_dir / src.name).write_text(content)
    print(f"  wrote {src.name}")
PYEOF

# ── Push manifests to your winget-pkgs fork ────────────────────────────────────
echo ""
echo "==> Pushing manifests to fork..."

FORK_OWNER=$(gh api user --jq .login)
BRANCH="lumos-${VERSION}"

cd "$WINGET_PKGS_LOCAL"
git fetch upstream 2>/dev/null || git fetch origin
git checkout -b "$BRANCH" upstream/master 2>/dev/null || git checkout -b "$BRANCH" origin/master
mkdir -p "$MANIFEST_PATH"
cp "$TMP_DIR/$MANIFEST_PATH/"*.yaml "$MANIFEST_PATH/"
git add "$MANIFEST_PATH"
git commit -m "Add LumosRobotics.Lumos version ${VERSION}"
git push origin "$BRANCH"

# ── Open PR ────────────────────────────────────────────────────────────────────
echo ""
echo "==> Creating pull request..."

PR_URL=$(gh pr create \
    --repo "$WINGET_PKGS_REPO" \
    --head "${FORK_OWNER}:${BRANCH}" \
    --title "New version: LumosRobotics.Lumos ${VERSION}" \
    --body "$(cat <<EOF
## LumosRobotics.Lumos ${VERSION}

- **Release**: https://github.com/${GITHUB_REPO}/releases/tag/v${VERSION}
- **Manifest type**: portable (zip)
- **Architecture**: x64

Auto-generated by [LumosTool publish_winget](https://github.com/${GITHUB_REPO}).
EOF
)")

echo ""
echo "==> Done! Winget PR submitted: $PR_URL"
